{
    "name": "wih-cement/wih-cement",
    "description": "Main site extension for WIH Cement",
    "type": "typo3-cms-extension",
    "license": "GPL-2.0-or-later",
    "require": {
        "typo3/cms-core": "^12.0 || ^13.0 || ^14.0",
        "typo3/cms-fluid-styled-content": "^12.0 || ^13.0 || ^14.0",
        "typo3/cms-form": "^12.0 || ^13.0 || ^14.0",
        "typo3/cms-felogin": "^12.0 || ^13.0 || ^14.0",
        "typo3/cms-seo": "^12.0 || ^13.0 || ^14.0"
    },
    "autoload": {
        "psr-4": {
            "WihCement\\WihCement\\": "Classes/"
        }
    },
    "extra": {
        "typo3/cms": {
            "extension-key": "wih_cement",
            "site-sets": [
                "Configuration/Sets/WihCement"
            ]
        }
    }
}
